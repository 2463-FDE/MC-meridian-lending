# dependencies
node_modules/
.pnp
.pnp.js

# python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.pytest_cache/
.mypy_cache/

# next.js
frontend/.next/
frontend/out/
frontend/build/

# misc
.DS_Store
*.log.bak
coverage/
.idea/
.vscode/

# secrets — never commit real credentials. Ship .env.example only.
.env
.env.local
.env.*.local
!.env.example
*.pem
*.key

# logs — never commit runtime logs; they can carry unredacted PII (raw PANs/SSNs
# were found in a checked-in log; see docs/security-remediation-2026-07.md). If
# finance needs a sample, commit ONE redacted example explicitly. NOTE:
# untracking does not purge PII already in git history — a history rewrite
# (git filter-repo / BFG) is still required separately.
logs/
**/logs/
*.log

# secrets — never commit real credentials. The LLM/Bedrock key belongs in the
# host shell env or an untracked override file, NOT in the committed .env.
.env.local
.env.*.local
*.pem
*.key

# rag_eval harness artifacts (generated per run; report re-generated by python -m rag_eval.run)
rag_eval/.cache/
rag_eval/eval_report.md
