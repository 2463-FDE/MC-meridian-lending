# Copy to .env and fill in with real values from your secret manager / host env.
# Do NOT commit a populated .env — it is git-ignored (was previously committed with
# live secrets; purged, see docs/security-remediation-2026-07.md).
POSTGRES_USER=meridian
POSTGRES_PASSWORD=
POSTGRES_DB=meridian
DB_HOST=postgres
DB_PORT=5432
DB_PASSWORD=
# DATABASE_URL must embed the SAME password you set in POSTGRES_PASSWORD above.
# Replace the placeholder below — a passwordless URL (meridian:@postgres) will pass
# `docker compose up` (only POSTGRES_PASSWORD is validated) but fail DB auth at
# runtime, and /health does not exercise the DB so the stack looks deployable.
DATABASE_URL=postgresql://meridian:REPLACE_WITH_POSTGRES_PASSWORD@postgres:5432/meridian
REDIS_URL=redis://redis:6379/0
# Deployment environment. Leave as production (or any non-development value) for
# real deploys — synthetic credit scoring is HARD-REFUSED unless this is exactly
# "development", so a copied config can never approve loans on fake data.
ENVIRONMENT=production
CORE_BANKING_API_KEY=
EXPERIAN_KEY=
EXPERIAN_BASE_URL=https://api.experian.example.com/v2
# Synthetic-credit escape hatch — intentionally NOT enabled here. A copied
# .env.example must fail closed: with no EXPERIAN_KEY the decision endpoint
# returns 503 and /health reports unhealthy. To run the local demo WITHOUT a live
# bureau, use the demo override instead of editing this file:
#   docker compose -f docker-compose.yml -f docker-compose.demo.yml up
# (that override sets ENVIRONMENT=development + ALLOW_SYNTHETIC_CREDIT=1 — both
# gates are required, so neither one alone can enable it.)
PROCESSOR_API_KEY=
PROCESSOR_BASE_URL=https://api.cardprocessor.example.com
ORIGINATION_URL=http://origination-service:8001
SERVICING_URL=http://servicing-service:8002
KYC_URL=http://kyc-service:8003
DECISION_URL=http://decision-service:8004
DISCLOSURE_URL=http://disclosure-service:8005
PAYMENT_URL=http://payment-service:8006
SESSION_TTL_SECONDS=28800
# Shared secret marking a request as an internal service-to-service call. Required by
# every internal-only route: decision-service (POST /decisions, GET record), origination
# (monthly-debt remediation), kyc-service (POST /kyc/check), disclosure-service
# (POST /offers). The gateway strips any client-supplied X-Internal-Service so it can
# never be forged from outside; origination forwards it on its downstream calls. Set the
# SAME value for ALL services (compose loads .env for every service). Leave blank to fail
# closed (those routes then return 503). Host-env/secret-manager only — never commit a
# real value.
INTERNAL_SERVICE_TOKEN=
# Pepper for the decision-service SSN idempotency fingerprint (PR review). A reused
# Idempotency-Key arriving with a changed SSN must not replay a stale decision; the
# service stores only an HMAC of the SSN (never the SSN) and compares it.
#
# NO committed value — the digest is only non-reversible while the pepper is SECRET, and
# an SSN is a 9-digit space, so a public pepper here would let anyone with decision_events
# access brute-force the stored fingerprints back to SSNs. Blank (or a placeholder) is
# treated as NO pepper: the fingerprint is not persisted and, outside development, /health
# reports unhealthy. Set a real secret from a secret-manager in any non-dev deploy. The
# local demo supplies a dev-only value via docker-compose.demo.yml (development env).
DECISION_FINGERPRINT_PEPPER=
LOG_LEVEL=INFO
# --- LLM (Claude) ---
# DO NOT put the real key in the committed .env. Export it in your shell
# (`export CLAUDE_API_KEY=...`) or an untracked .env.local. docker-compose reads
# it from the host env; the app fails loud at boot if it is required and missing.
CLAUDE_API_KEY=
# Optional overrides (safe to commit — no secrets):
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# CLAUDE_TIMEOUT=30
# CLAUDE_TOKEN_BUDGET=20000
#
# CLAUDE_PROVIDER=anthropic (default) | bedrock
# Set to `bedrock` to route through Amazon Bedrock instead of the direct
# Anthropic API — CLAUDE_API_KEY is then ignored, AWS credentials are used
# instead. Same host-env-only rule applies: AWS_BEARER_TOKEN_BEDROCK=... or the
# standard AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_REGION (prefer an IAM
# role over static keys). Never commit any of these.
# CLAUDE_PROVIDER=bedrock
# AWS_REGION=us-east-1
#
# --- LangSmith tracing (optional, off by default) ---
# Traces origination-service LLM calls to smith.langchain.com. Trace payloads
# are limited to the post-redaction request (what the provider already sees) —
# see app/llm/client.py / transport.py. Same host-env-only rule as
# CLAUDE_API_KEY: export LANGSMITH_API_KEY in your shell, never commit it.
# LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=2463-FDE
