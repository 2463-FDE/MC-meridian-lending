# Copy to .env and fill in with real values from your secret manager / host env.
# Do NOT commit a populated .env — it is git-ignored (was previously committed with
# live secrets; purged, see docs/security-remediation-2026-07.md).
POSTGRES_USER=meridian
POSTGRES_PASSWORD=
POSTGRES_DB=meridian
DB_HOST=postgres
DB_PORT=5432
DB_PASSWORD=
# DATABASE_URL must embed the SAME password you set in POSTGRES_PASSWORD above.
# Replace the placeholder below — a passwordless URL (meridian:@postgres) will pass
# `docker compose up` (only POSTGRES_PASSWORD is validated) but fail DB auth at
# runtime, and /health does not exercise the DB so the stack looks deployable.
DATABASE_URL=postgresql://meridian:REPLACE_WITH_POSTGRES_PASSWORD@postgres:5432/meridian
REDIS_URL=redis://redis:6379/0
CORE_BANKING_API_KEY=
EXPERIAN_KEY=
EXPERIAN_BASE_URL=https://api.experian.example.com/v2
# LOCAL/DEMO ONLY. With no live Experian key, set this so decision-service falls
# back to a deterministic synthetic score. Leave UNSET in any real environment:
# without it, a missing EXPERIAN_KEY fails closed (no decision) and /health reports
# unhealthy — the intended production behaviour.
ALLOW_SYNTHETIC_CREDIT=1
PROCESSOR_API_KEY=
PROCESSOR_BASE_URL=https://api.cardprocessor.example.com
ORIGINATION_URL=http://origination-service:8001
SERVICING_URL=http://servicing-service:8002
KYC_URL=http://kyc-service:8003
DECISION_URL=http://decision-service:8004
DISCLOSURE_URL=http://disclosure-service:8005
PAYMENT_URL=http://payment-service:8006
SESSION_TTL_SECONDS=28800
LOG_LEVEL=INFO
ENVIRONMENT=development
